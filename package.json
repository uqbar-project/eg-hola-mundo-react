{
  "name": "eg-hola-mundo-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules coverage",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@testing-library/react": "16.2.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "3.0.5",
    "@vitest/ui": "3.0.5",
    "jsdom": "26.0.0",
    "typescript": "5.7.3",
    "vite": "6.4.2",
    "vitest": "3.0.5"
  }
}
